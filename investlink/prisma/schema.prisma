datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserType {
  STARTUP
  INVESTOR
  EXPERT
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String?
  phone              String?            @unique
  image              String?
  passwordHash       String?
  type               UserType           @default(STARTUP)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  onboardingStatus   OnboardingStatus   @default(NOT_STARTED)

  /// Full wizard answers (JSON) for analytics, debugging, and future remapping
  onboardingPayload Json?

  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]
  notifications Notification[]

  expertProfile   ExpertProfile?
  investorProfile InvestorProfile?
  startupProfile  StartupProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpertProfile {
  id     String @id @default(cuid())
  userId String @unique

  /// identity / public profile
  firstName    String?
  lastName     String?
  title        String?
  headline     String?
  bio          String?
  country      String?
  city         String?
  linkedinUrl  String?
  website      String?
  portfolioUrl String?

  /// filtering / matching
  yearsExperience  Int?
  primaryCategory  String?
  skills           String[]
  industries       String[]
  areasOfExpertise String[]

  /// commercial / availability
  hourlyRateUsd       Int?
  minProjectBudgetUsd Int?
  availability        String?
  noticePeriod        String?

  /// collaboration
  collaborationTypes     String[]
  preferredStartupStages String[]
  collaborationInterests String[]

  /// credibility
  pastClients    String?
  certifications String[]
  extras         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  receivedInvitations CollaborationInvitation[]
  collaborations      StartupExpertCollaboration[]

  @@index([primaryCategory])
  @@index([yearsExperience])
  @@index([country])
  @@index([city])
}

model InvestorProfile {
  id     String @id @default(cuid())
  userId String @unique

  /// identity / public profile
  firstName         String?
  lastName          String?
  country           String?
  city              String?
  professionalTitle String?
  linkedinUrl       String?
  bio               String?

  /// investor classification
  investorType      String?
  investorTypeOther String?

  /// filtering / matching
  sectors     String[]
  stages      String[]
  geographies String[]

  /// capital profile
  budgetMinUsd        Int?
  budgetMaxUsd        Int?
  ticketMinUsd        Int?
  ticketMaxUsd        Int?
  riskAppetite        String?
  investmentFrequency String?

  /// preferences
  preferredStartupValues String[]
  involvementTypes       String[]
  coInvestingPreference  String?
  hearAboutSource        String?

  /// background / trust signals
  previousInvestments String?
  successfulExits     String?

  /// flexible storage
  strategicNotes Json?
  extras         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Investitor↔startup.
  investmentInterests InvestmentInterest[]
  investmentRecords   Investment[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([investorType])
  @@index([riskAppetite])
  @@index([country])
  @@index([city])
}

model StartupProfile {
  id     String @id @default(cuid())
  userId String @unique

  /// identity / public profile
  companyName     String?
  legalEntityType String?
  country         String?
  city            String?
  website         String?
  linkedinUrl     String?

  /// company summary
  oneLiner   String?
  shortPitch String?
  problem    String?
  solution   String?

  /// classification / filtering
  industries     String[]
  businessModels String[]
  companyStage   String?
  fundingStage   String?
  foundedYear    Int?

  /// fundraising
  fundraisingGoalUsd Int?
  minCheckUsd        Int?
  maxCheckUsd        Int?
  useOfFunds         String[]

  /// traction / team
  founderCount      Int?
  teamSize          Int?
  tractionSummary   String?
  monthlyRevenueUsd Int?
  monthlyGrowthRate Float?
  usersCount        Int?

  /// needs / matching
  expertNeeds   String[]
  hiringNeeds   String[]
  startupValues String[]

  /// assets
  deckUrl       String?
  pitchVideoUrl String?

  /// flexible storage
  extras Json?
  expertCollaborations StartupExpertCollaboration[]
  /// Numele spune "sent" din motive istorice (pasul 2, când doar startup-ul
  /// trimitea). De la fluxul bidirecțional, relația conține TOATE cererile
  /// de colaborare ale acestui startup — și invitațiile trimise de el
  /// (initiatedBy=STARTUP), și aplicațiile primite de la experți
  /// (initiatedBy=EXPERT). Filtrează pe initiatedBy când contează direcția.
  sentInvitations      CollaborationInvitation[]

  // Investitor↔startup (fluxul nou).
  investmentInterests InvestmentInterest[]
  investmentRecords   Investment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyStage])
  @@index([fundingStage])
  @@index([country])
  @@index([city])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum ExpertCollaborationStatus {
  ACTIVE
  BUSY
  COMPLETED
  PAUSED
  CANCELLED
}

model StartupExpertCollaboration {
  id                  String                    @id @default(cuid())
  startupProfileId    String
  /// FK opțional: setat când colaborarea provine dintr-o invitație acceptată
  /// pe platformă. Rămâne null pentru colaborări cu experți externi introduse
  /// manual (doar displayName). Astfel modelul suportă ambele cazuri.
  expertProfileId     String?
  displayName         String
  roleTitle           String
  status              ExpertCollaborationStatus @default(ACTIVE)
  hourlyRate          Decimal?                  @db.Decimal(10, 2)
  totalPaid           Decimal                   @default(0) @db.Decimal(14, 2)
  workloadPercent     Int?
  projectsCount       Int                       @default(1)
  currentProjectTitle String?

  /// ── Terminare + feedback privat (bidirecțional) ──
  /// Setate la încheierea colaborării. endedBy = cine a apăsat "termină".
  /// Rating-urile sunt 1-5, private pe colaborare (nu publice, nu în director).
  /// startupRating = nota pe care startup-ul o dă expertului; expertRating = invers.
  endReason           String?
  endedBy             CollaborationParty?
  startupRating       Int?
  startupComment      String?
  expertRating        Int?
  expertComment       String?

  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  startupProfile StartupProfile @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)
  expertProfile  ExpertProfile? @relation(fields: [expertProfileId], references: [id], onDelete: SetNull)

  @@index([startupProfileId])
  @@index([expertProfileId])
}

/// Cine a inițiat o acțiune pe colaborare (terminare, feedback).
enum CollaborationParty {
  STARTUP
  EXPERT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

model CollaborationInvitation {
  id               String           @id @default(cuid())
  startupProfileId String
  expertProfileId  String
  roleTitle        String
  message          String?
  /// Cine a inițiat cererea: STARTUP = invitație (oferă rol), EXPERT = aplicație
  /// (se propune la un rol). Determină cine RĂSPUNDE: partea opusă lui initiatedBy.
  /// Default STARTUP păstrează invitațiile existente corecte fără migrare de date.
  initiatedBy      CollaborationParty @default(STARTUP)
  status           InvitationStatus @default(PENDING)
  respondedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  startupProfile StartupProfile @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)
  expertProfile  ExpertProfile  @relation(fields: [expertProfileId], references: [id], onDelete: Cascade)

  // Unicitatea reală ("max o invitație PENDING per pereche") NU se poate
  // exprima declarativ în Prisma — e un partial unique index pe status=PENDING,
  // adăugat prin SQL manual în migrarea de la pasul 4.5. Un @@unique clasic pe
  // [startup, expert, status] ar rupe istoricul repetat de colaborări (ai putea
  // avea o singură invitație ACCEPTED per pereche, deci o singură colaborare
  // vreodată). Vezi migration.sql.
  @@index([expertProfileId, status])
  @@index([startupProfileId, status])
}

// ═══════════════════════════════════════════════════════════════════
// INVESTITOR ↔ STARTUP
// ═══════════════════════════════════════════════════════════════════

/// Cine a inițiat cererea de interes investitor-startup.
/// Enum separat de CollaborationParty (STARTUP/EXPERT) intenționat — un enum
/// nu trebuie să însemne lucruri diferite în contexte diferite.
enum InvestmentParty {
  INVESTOR
  STARTUP
}

/// Statusul unei cereri de interes (match investitor-startup).
/// Semantica e a unui match (cerere de interes), nu a unei investiții.
/// nu a unei investiții.
enum InvestmentInterestStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

/// EXPRESIA DE INTERES (match-ul). Paralel cu CollaborationInvitation, dar
/// pentru investitor↔startup. Bidirecțional: oricare parte poate iniția.
/// Răspunde partea opusă lui initiatedBy. NU conține date financiare — doar
/// "am fost de acord să discutăm o investiție". Datele reale sunt în Investment.
model InvestmentInterest {
  id                String                   @id @default(cuid())
  investorProfileId String
  startupProfileId  String
  message           String?
  /// INVESTOR = investitorul își exprimă interesul într-un startup.
  /// STARTUP = startup-ul își exprimă interesul către un investitor.
  initiatedBy       InvestmentParty
  status            InvestmentInterestStatus @default(PENDING)
  respondedAt       DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  investorProfile InvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  startupProfile  StartupProfile  @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)

  // Blocarea strictă ("max o cerere PENDING per pereche") se impune printr-un
  // partial unique index adăugat prin SQL manual (vezi migrarea), la fel ca la
  // CollaborationInvitation. Un @@unique clasic ar rupe istoricul repetat.
  @@index([investorProfileId, status])
  @@index([startupProfileId, status])
}

/// EVIDENȚA FINANCIARĂ. Date introduse MANUAL de startup (sursă unică de
/// adevăr), agregate de platformă pentru statistică. NU e procesare de bani —
/// platforma nu verifică, nu mișcă fonduri; e evidența fondatorului despre
/// propriul business, făcută utilă prin agregare.
///
/// Legat de InvestorProfile + StartupProfile prin FK-uri REALE (spre deosebire
/// (scheletul vechi, șters în pasul E, lega de un model separat de companie
/// și de text liber — de aceea datele nu se uneau).
///
/// investorProfileId e opțional: un startup poate înregistra o investiție de la
/// un investitor care NU e pe platformă (înger extern, fond) — atunci doar
/// investorName. Simetric cu displayName de la colaborări externe.
model Investment {
  id                String    @id @default(cuid())
  startupProfileId  String
  investorProfileId String?
  /// Nume afișat — pentru investitori externi (fără profil) sau ca fallback.
  investorName      String
  amountUsd         Decimal   @db.Decimal(18, 2)
  round             String?
  equityPercent     Decimal?  @db.Decimal(8, 4)
  investedAt        DateTime
  note              String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  startupProfile  StartupProfile   @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)
  investorProfile InvestorProfile? @relation(fields: [investorProfileId], references: [id], onDelete: SetNull)

  @@index([startupProfileId])
  @@index([investorProfileId])
}

// ═══════════════════════════════════════════════════════════════════
// NOTIFICĂRI
// ═══════════════════════════════════════════════════════════════════

/// Tipul evenimentului. Enum (nu text liber) ca să putem filtra/grupa mai
/// târziu și ca să nu se strecoare tipuri inventate în cod.
enum NotificationType {
  COLLABORATION_INVITATION_RECEIVED
  COLLABORATION_APPLICATION_RECEIVED
  COLLABORATION_REQUEST_ACCEPTED
  COLLABORATION_REQUEST_DECLINED
  COLLABORATION_ENDED
  INVESTMENT_INTEREST_RECEIVED
  INVESTMENT_INTEREST_ACCEPTED
  INVESTMENT_INTEREST_DECLINED
}

/// O notificare in-app pentru un utilizator.
///
/// Textul e DENORMALIZAT (title/body scrise la momentul evenimentului), nu
/// reconstruit din referințe. O notificare e jurnalul a ce s-a întâmplat
/// atunci: dacă expertul își schimbă numele mâine, notificarea de acum o lună
/// trebuie să rămână cum a fost. Bonus: randare cu un singur query.
///
/// Destinatarul e User (nu profilul de rol) — un om are un singur inbox.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  /// Unde duce click-ul, ex. "/dashboard/startup/applications".
  linkPath  String?
  /// null = necitită. Timestamp = momentul citirii.
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Necitite pentru badge + listare cronologică.
  @@index([userId, readAt])
  @@index([userId, createdAt])
}
