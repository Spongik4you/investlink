datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserType {
  STARTUP
  INVESTOR
  EXPERT
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String?
  phone              String?            @unique
  image              String?
  passwordHash       String?
  type               UserType           @default(STARTUP)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  onboardingStatus   OnboardingStatus   @default(NOT_STARTED)

  /// Full wizard answers (JSON) for analytics, debugging, and future remapping
  onboardingPayload Json?

  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]

  expertProfile   ExpertProfile?
  investorProfile InvestorProfile?
  startupProfile  StartupProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpertProfile {
  id     String @id @default(cuid())
  userId String @unique

  /// identity / public profile
  firstName    String?
  lastName     String?
  title        String?
  headline     String?
  bio          String?
  country      String?
  city         String?
  linkedinUrl  String?
  website      String?
  portfolioUrl String?

  /// filtering / matching
  yearsExperience  Int?
  primaryCategory  String?
  skills           String[]
  industries       String[]
  areasOfExpertise String[]

  /// commercial / availability
  hourlyRateUsd       Int?
  minProjectBudgetUsd Int?
  availability        String?
  noticePeriod        String?

  /// collaboration
  collaborationTypes     String[]
  preferredStartupStages String[]
  collaborationInterests String[]

  /// credibility
  pastClients    String?
  certifications String[]
  extras         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([primaryCategory])
  @@index([yearsExperience])
  @@index([country])
  @@index([city])
}

model InvestorProfile {
  id     String @id @default(cuid())
  userId String @unique

  /// identity / public profile
  firstName         String?
  lastName          String?
  country           String?
  city              String?
  professionalTitle String?
  linkedinUrl       String?
  bio               String?

  /// investor classification
  investorType      String?
  investorTypeOther String?

  /// filtering / matching
  sectors     String[]
  stages      String[]
  geographies String[]

  /// capital profile
  budgetMinUsd        Int?
  budgetMaxUsd        Int?
  ticketMinUsd        Int?
  ticketMaxUsd        Int?
  riskAppetite        String?
  investmentFrequency String?

  /// preferences
  preferredStartupValues String[]
  involvementTypes       String[]
  coInvestingPreference  String?
  hearAboutSource        String?

  /// background / trust signals
  previousInvestments String?
  successfulExits     String?

  /// flexible storage
  strategicNotes Json?
  extras         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([investorType])
  @@index([riskAppetite])
  @@index([country])
  @@index([city])
}

model StartupProfile {
  id     String @id @default(cuid())
  userId String @unique

  /// identity / public profile
  companyName     String?
  legalEntityType String?
  country         String?
  city            String?
  website         String?
  linkedinUrl     String?

  /// company summary
  oneLiner   String?
  shortPitch String?
  problem    String?
  solution   String?

  /// classification / filtering
  industries     String[]
  businessModels String[]
  companyStage   String?
  fundingStage   String?
  foundedYear    Int?

  /// fundraising
  fundraisingGoalUsd Int?
  minCheckUsd        Int?
  maxCheckUsd        Int?
  useOfFunds         String[]

  /// traction / team
  founderCount      Int?
  teamSize          Int?
  tractionSummary   String?
  monthlyRevenueUsd Int?
  monthlyGrowthRate Float?
  usersCount        Int?

  /// needs / matching
  expertNeeds   String[]
  hiringNeeds   String[]
  startupValues String[]

  /// assets
  deckUrl       String?
  pitchVideoUrl String?

  /// flexible storage
  extras Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyStage])
  @@index([fundingStage])
  @@index([country])
  @@index([city])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
