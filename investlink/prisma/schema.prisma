enum FundingRoundStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
}

enum InvestmentStatus {
  PENDING
  ACTIVE
  DECLINED
  COMPLETED
}

enum InvestorRelationStatus {
  PIPELINE
  PENDING
  ACTIVE
  INACTIVE
}

enum ExpertCollaborationStatus {
  ACTIVE
  BUSY
  COMPLETED
  PAUSED
  CANCELLED
}

model StartupFundingRound {
  id                   String             @id @default(cuid())
  startupProfileId     String
  title                String
  targetAmount         Decimal            @db.Decimal(14, 2)
  raisedAmount         Decimal            @default(0) @db.Decimal(14, 2)
  equityOfferedPercent Decimal?           @db.Decimal(5, 2)
  status               FundingRoundStatus @default(DRAFT)
  openedAt             DateTime?
  closedAt             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  startupProfile StartupProfile      @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)
  investments    StartupInvestment[]

  @@index([startupProfileId])
}

model StartupInvestorRelation {
  id               String                 @id @default(cuid())
  startupProfileId String
  displayName      String
  organizationName String?
  status           InvestorRelationStatus @default(PIPELINE)
  email            String?
  totalCommitted   Decimal                @default(0) @db.Decimal(14, 2)
  equityPercent    Decimal?               @db.Decimal(5, 2)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  startupProfile StartupProfile      @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)
  investments    StartupInvestment[]

  @@index([startupProfileId])
}

model StartupInvestment {
  id                        String           @id @default(cuid())
  startupFundingRoundId     String
  startupInvestorRelationId String
  amount                    Decimal          @db.Decimal(14, 2)
  equityPercent             Decimal?         @db.Decimal(5, 2)
  status                    InvestmentStatus @default(PENDING)
  investedAt                DateTime?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  fundingRound     StartupFundingRound     @relation(fields: [startupFundingRoundId], references: [id], onDelete: Cascade)
  investorRelation StartupInvestorRelation @relation(fields: [startupInvestorRelationId], references: [id], onDelete: Cascade)

  @@index([startupFundingRoundId])
  @@index([startupInvestorRelationId])
}

model StartupExpertCollaboration {
  id                  String                    @id @default(cuid())
  startupProfileId    String
  /// FK opțional: setat când colaborarea provine dintr-o invitație acceptată
  /// pe platformă. Rămâne null pentru colaborări cu experți externi introduse
  /// manual (doar displayName). Astfel modelul suportă ambele cazuri.
  expertProfileId     String?
  displayName         String
  roleTitle           String
  status              ExpertCollaborationStatus @default(ACTIVE)
  hourlyRate          Decimal?                  @db.Decimal(10, 2)
  totalPaid           Decimal                   @default(0) @db.Decimal(14, 2)
  workloadPercent     Int?
  projectsCount       Int                       @default(1)
  currentProjectTitle String?

  /// ── Terminare + feedback privat (bidirecțional) ──
  /// Setate la încheierea colaborării. endedBy = cine a apăsat "termină".
  /// Rating-urile sunt 1-5, private pe colaborare (nu publice, nu în director).
  /// startupRating = nota pe care startup-ul o dă expertului; expertRating = invers.
  endReason           String?
  endedBy             CollaborationParty?
  startupRating       Int?
  startupComment      String?
  expertRating        Int?
  expertComment       String?

  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  startupProfile StartupProfile @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)
  expertProfile  ExpertProfile? @relation(fields: [expertProfileId], references: [id], onDelete: SetNull)

  @@index([startupProfileId])
  @@index([expertProfileId])
}

/// Cine a inițiat o acțiune pe colaborare (terminare, feedback).
enum CollaborationParty {
  STARTUP
  EXPERT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

model CollaborationInvitation {
  id               String           @id @default(cuid())
  startupProfileId String
  expertProfileId  String
  roleTitle        String
  message          String?
  /// Cine a inițiat cererea: STARTUP = invitație (oferă rol), EXPERT = aplicație
  /// (se propune la un rol). Determină cine RĂSPUNDE: partea opusă lui initiatedBy.
  /// Default STARTUP păstrează invitațiile existente corecte fără migrare de date.
  initiatedBy      CollaborationParty @default(STARTUP)
  status           InvitationStatus @default(PENDING)
  respondedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  startupProfile StartupProfile @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)
  expertProfile  ExpertProfile  @relation(fields: [expertProfileId], references: [id], onDelete: Cascade)

  // Unicitatea reală ("max o invitație PENDING per pereche") NU se poate
  // exprima declarativ în Prisma — e un partial unique index pe status=PENDING,
  // adăugat prin SQL manual în migrarea de la pasul 4.5. Un @@unique clasic pe
  // [startup, expert, status] ar rupe istoricul repetat de colaborări (ai putea
  // avea o singură invitație ACCEPTED per pereche, deci o singură colaborare
  // vreodată). Vezi migration.sql.
  @@index([expertProfileId, status])
  @@index([startupProfileId, status])
}

// ═══════════════════════════════════════════════════════════════════
// INVESTITOR ↔ STARTUP
// ═══════════════════════════════════════════════════════════════════

/// Cine a inițiat cererea de interes investitor-startup.
/// Enum separat de CollaborationParty (STARTUP/EXPERT) intenționat — un enum
/// nu trebuie să însemne lucruri diferite în contexte diferite.
enum InvestmentParty {
  INVESTOR
  STARTUP
}

/// Statusul unei cereri de interes (match investitor-startup).
/// Separat de InvestmentStatus (scheletul vechi) — semantica e a unui match,
/// nu a unei investiții.
enum InvestmentInterestStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

/// EXPRESIA DE INTERES (match-ul). Paralel cu CollaborationInvitation, dar
/// pentru investitor↔startup. Bidirecțional: oricare parte poate iniția.
/// Răspunde partea opusă lui initiatedBy. NU conține date financiare — doar
/// "am fost de acord să discutăm o investiție". Datele reale sunt în Investment.
model InvestmentInterest {
  id                String                   @id @default(cuid())
  investorProfileId String
  startupProfileId  String
  message           String?
  /// INVESTOR = investitorul își exprimă interesul într-un startup.
  /// STARTUP = startup-ul își exprimă interesul către un investitor.
  initiatedBy       InvestmentParty
  status            InvestmentInterestStatus @default(PENDING)
  respondedAt       DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  investorProfile InvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
  startupProfile  StartupProfile  @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)

  // Blocarea strictă ("max o cerere PENDING per pereche") se impune printr-un
  // partial unique index adăugat prin SQL manual (vezi migrarea), la fel ca la
  // CollaborationInvitation. Un @@unique clasic ar rupe istoricul repetat.
  @@index([investorProfileId, status])
  @@index([startupProfileId, status])
}

/// EVIDENȚA FINANCIARĂ. Date introduse MANUAL de startup (sursă unică de
/// adevăr), agregate de platformă pentru statistică. NU e procesare de bani —
/// platforma nu verifică, nu mișcă fonduri; e evidența fondatorului despre
/// propriul business, făcută utilă prin agregare.
///
/// Legat de InvestorProfile + StartupProfile prin FK-uri REALE (spre deosebire
/// de scheletul vechi InvestmentPosition/StartupInvestorRelation care lega de
/// StartupCompany / text liber). Asta unifică cele două universuri financiare.
///
/// investorProfileId e opțional: un startup poate înregistra o investiție de la
/// un investitor care NU e pe platformă (înger extern, fond) — atunci doar
/// investorName. Simetric cu displayName de la colaborări externe.
model Investment {
  id                String    @id @default(cuid())
  startupProfileId  String
  investorProfileId String?
  /// Nume afișat — pentru investitori externi (fără profil) sau ca fallback.
  investorName      String
  amountUsd         Decimal   @db.Decimal(18, 2)
  round             String?
  equityPercent     Decimal?  @db.Decimal(8, 4)
  investedAt        DateTime
  note              String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  startupProfile  StartupProfile   @relation(fields: [startupProfileId], references: [id], onDelete: Cascade)
  investorProfile InvestorProfile? @relation(fields: [investorProfileId], references: [id], onDelete: SetNull)

  @@index([startupProfileId])
  @@index([investorProfileId])
}
